# Secrets (never commit)
**/config/tokens.env
**/*.env
!**/*.env.example

# Webhook maps are secrets (never commit)
**/config/channel_map.json

# Fetchall UI runtime overrides (never commit; persists across !mwupdate python-only updates)
**/config/fetchall_mappings.runtime.json

# Runtime settings overrides (never commit)
**/config/settings.runtime.json

# Runtime / logs (never commit)
**/logs/**
**/*.log
**/*.jsonl
**/config/systemlogs.json
**/*.lock
**/.d2d.lock

# Python junk
**/__pycache__/
**/*.pyc

# Discum channel caches are runtime artifacts (never commit)
MWDiscumBot/config/source_channels.json
MWDiscumBot/config/destination_channels.json

# WhopMembershipSync secrets (never commit)
WhopMembershipSync/config.secrets.json

# Never commit bot secrets in MWBots repo
**/config.secrets.json

# Instorebotforwarder runtime / local auth (never commit)
Instorebotforwarder/.instorebotforwarder.lock
Instorebotforwarder/mavely_cookies*.txt
Instorebotforwarder/mavely_refresh_token*.txt
Instorebotforwarder/mavely_auth_token*.txt
Instorebotforwarder/mavely_id_token*.txt
Instorebotforwarder/playwright_profile/**
Instorebotforwarder/.playwright/**
Instorebotforwarder/api-token.env