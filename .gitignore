# Secrets (never commit)
**/config/tokens.env
**/*.env
!**/*.env.example

# Webhook maps are secrets (never commit)
**/config/channel_map.json

# MWDiscumBot fetchall_mappings.runtime.json + settings.runtime.json are tracked (push_mwbots_py_only stages them)
# so Oracle/mwbots-code matches your intended overlay. Do not put secrets in those JSON files.

# Runtime / logs (never commit)
**/logs/**
**/*.log
**/*.jsonl
**/config/systemlogs.json
**/*.lock
**/.d2d.lock

# Python junk
**/__pycache__/
**/*.pyc

# Discum channel caches are runtime artifacts (never commit)
MWDiscumBot/config/source_channels.json
MWDiscumBot/config/destination_channels.json

# WhopMembershipSync secrets (never commit)
WhopMembershipSync/config.secrets.json

# Never commit bot secrets in MWBots repo
**/config.secrets.json

# Instorebotforwarder runtime / local auth (never commit)
Instorebotforwarder/.instorebotforwarder.lock
Instorebotforwarder/mavely_cookies*.txt
Instorebotforwarder/mavely_refresh_token*.txt
Instorebotforwarder/mavely_auth_token*.txt
Instorebotforwarder/mavely_id_token*.txt
Instorebotforwarder/playwright_profile/**
Instorebotforwarder/.playwright/**
# Oracle/direct downloads include an extra nested folder:
# MWBots/Instorebotforwarder/Instorebotforwarder/playwright_profile/...
Instorebotforwarder/Instorebotforwarder/playwright_profile/**
Instorebotforwarder/Instorebotforwarder/.playwright/**
Instorebotforwarder/api-token.env

# Universal link resolver (local batch outputs / URL lists — not deploy artifacts)
MWDataManagerBot/universal_link_resolver_v2_ready/last_result.json
MWDataManagerBot/universal_link_resolver_v2_ready/urls.txt
